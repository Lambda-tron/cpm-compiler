class test{
  volatile i : int := 0
  volatile total : int := 0
  testo(par : int, mi : float): int {
    volatile  list: float[] := float[5.0, 6.0, 1.0, 2.4, 2.3, 2.5, 9.0, 14.0, 2.0, 15.0, 6.0, 7.0, 8.0, 97.0]
    volatile n : int := list.length
    volatile i : int := 0
    for (i := 0, i < n, i := i + 1) {
      print(list[i])
      //return 1
    }
    return 0
  }
  func(): int {
    volatile n : int
    read(n)

    volatile x : int := 1
    volatile i : int := 2

    for (i := 2, i <= n, i := i + 1) {
      x := x * i
    }

    if (x < 3) {
      x := 0
    }

    print(x)
    return 0
  }
}

main(): int {
  object : test := test()
  volatile n : int := object.testo(4, 5.4)
  read(n)
  if (n < 3) {
    return 0
  }
  volatile x : int := 1
  volatile i : int := 2
  return 0
}